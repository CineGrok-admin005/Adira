# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Required: bypasses RLS to count all real signups

# Anthropic Claude API — switch back to this when credits are added
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API — temporary free alternative while Anthropic credits are zero
GROQ_API_KEY=your-groq-api-key-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-personal-chat-id

# YouTube Data API v3 (free — 10,000 units/day, no OAuth needed)
# Setup: console.cloud.google.com → APIs & Services → YouTube Data API v3 → Create API Key
YOUTUBE_API_KEY=your-youtube-api-key-here

# Twitter/X API
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your-linkedin-token
LINKEDIN_PERSON_ID=your-linkedin-person-id   # from /v2/userinfo .sub field
LINKEDIN_ORGANIZATION_ID=your-org-id
# LinkedIn tokens expire every 60 days. Set this to your token's expiry date (ISO format: 2026-06-23T00:00:00Z).
# The agent will send a Telegram warning when within 7 days of expiry.
LINKEDIN_TOKEN_EXPIRES_AT=

# Instagram / Meta
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id
META_PAGE_ACCESS_TOKEN=your-page-access-token

# App Config
NODE_ENV=production
TIMEZONE=Asia/Kolkata
# Set AUTO_POST=true to automatically post to Twitter + LinkedIn after Telegram review.
# Keep false to review drafts on Telegram manually before posting.
AUTO_POST=false
